# BOUT environment config
# Copy this file to .env and fill in only the providers you actually want to use.
# BOUT works with ZERO keys set — it falls back to the built-in mock model
# and sample data so the whole CLI is usable offline, immediately.

# --- Model provider selection -------------------------------------------------
# One of: mock | claude | openai | ollama
BOUT_MODEL_PROVIDER=mock

# --- Claude (Anthropic) -------------------------------------------------------
# Only needed if BOUT_MODEL_PROVIDER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI --------------------------------------------------------------------
# Only needed if BOUT_MODEL_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Ollama (local) -------------------------------------------------------------
# Only needed if BOUT_MODEL_PROVIDER=ollama
# No key required — just a local server URL and a model you've already pulled.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Misc ----------------------------------------------------------------------
# Where the local SQLite DB lives. Defaults to data/local/bout.db
BOUT_DB_PATH=
