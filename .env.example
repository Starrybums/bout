# BOUT environment config
# Copy this file to .env and fill in ONE of the providers below.
# BOUT has no offline/mock AI mode — `bout brief` and `bout confluence` will
# refuse to run until a real provider is configured here.
# (Ollama is free/local and needs no API key, if you'd rather not use one.)

# --- Model provider selection -------------------------------------------------
# One of: claude | openai | ollama
BOUT_MODEL_PROVIDER=

# --- Claude (Anthropic) -------------------------------------------------------
# Only needed if BOUT_MODEL_PROVIDER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- OpenAI --------------------------------------------------------------------
# Only needed if BOUT_MODEL_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Ollama (local) -------------------------------------------------------------
# Only needed if BOUT_MODEL_PROVIDER=ollama
# No key required — just a local server URL and a model you've already pulled.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Misc ----------------------------------------------------------------------
# Where the local SQLite DB lives. Defaults to data/local/bout.db
BOUT_DB_PATH=
